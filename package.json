{
  "name": "basamake-vscode",
  "displayName": "Basamake",
  "description": "Basamake language server for Scala",
  "repository": "https://github.com/sake92/basamake-vscode",
  "version": "0.1.0",
  "publisher": "local",
  "engines": { "vscode": "^1.85.0" },
  "scripts": {
    "package": "vsce package"
  },
  "main": "./extension.js",
  "dependencies": {
    "vscode-languageclient": "^8.1.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.6.2"
  },
  "contributes": {
    "languages": [
      {
        "id": "scala",
        "aliases": ["Scala", "scala"],
        "extensions": [".scala", ".sbt"],
        "configuration": "./scala-language-configuration.json"
      }
    ],
    "configuration": {
      "title": "Basamake",
      "properties": {
        "basamake.jarPath": {
          "type": "string",
          "default": "",
          "description": "Path to basamake fat JAR. If set, overrides download mechanism."
        },
        "basamake.serverVersion": {
          "type": "string",
          "default": "latest",
          "description": "Basamake version to download from GitHub releases. Use 'latest' to auto-resolve, or pin to a tag like 'v0.1.0'. Ignored when basamake.jarPath is set."
        },
        "basamake.jvmArgs": {
          "type": "array",
          "default": [],
          "items": { "type": "string" },
          "description": "Extra JVM args for the server."
        }
      }
    }
  }
}
